# Purpose: Document the canonical local environment variables for the Python services.
# Scope: Shared runtime configuration for the API, worker, storage, database, model gateway, and observability layers.
# Dependencies: Parsed by services/common/settings.py via flat lowercase variables.

runtime_environment=development
runtime_debug=false
runtime_service_name=accounting-ai-agent
runtime_timezone_name=Africa/Lagos
runtime_api_base_path=/api

logging_level=INFO
logging_format=json
logging_include_stack_info=false

api_host=127.0.0.1
api_port=8000
api_reload=false
api_request_timeout_seconds=30

worker_concurrency=2
worker_prefetch_multiplier=1
worker_max_tasks_per_child=100
worker_task_soft_time_limit_seconds=1500
worker_task_time_limit_seconds=1800
worker_result_expires_seconds=86400
worker_visibility_timeout_seconds=3600

DATABASE_URL=
database_host=127.0.0.1
database_port=5432
database_name=accounting_agent
database_user=accounting_agent
database_password=accounting_agent
database_schema_name=public
database_echo_sql=false

REDIS_URL=
redis_broker_url=redis://127.0.0.1:6379/0
redis_result_backend_url=redis://127.0.0.1:6379/1
redis_cache_url=redis://127.0.0.1:6379/2

ENDPOINT=
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
REGION=
BUCKET=
storage_endpoint=127.0.0.1:9000
storage_access_key=minioadmin
storage_secret_key=minioadmin
storage_secure=false
storage_region=us-east-1
storage_document_bucket=close-run-documents
storage_artifact_bucket=close-run-artifacts
storage_derivative_bucket=close-run-derivatives

model_gateway_provider=openrouter
model_gateway_base_url=https://openrouter.ai/api/v1
model_gateway_api_key=
model_gateway_default_model=openai/gpt-4.1-mini
model_gateway_timeout_seconds=60

quickbooks_client_id=
quickbooks_client_secret=
quickbooks_redirect_uri=http://127.0.0.1:8000/api/integrations/quickbooks/callback
quickbooks_sandbox_company_id=
quickbooks_use_sandbox=true
quickbooks_allowed_return_origins=

observability_service_namespace=accounting-agent
observability_otlp_endpoint=
observability_otlp_protocol=auto
observability_otlp_headers=
observability_sample_ratio=1.0

security_session_secret=change-me-before-demo-auth
security_token_signing_secret=change-me-before-cli-auth
security_credential_encryption_key=
security_session_cookie_name=accounting_agent_session
security_session_ttl_hours=12
security_session_rotation_minutes=30
