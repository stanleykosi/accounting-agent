# Purpose: Document the canonical local environment variables for the Python services.
# Scope: Shared runtime configuration for the API, worker, storage, database, model gateway, and observability layers.
# Dependencies: Parsed by services/common/settings.py via ACCOUNTING_AGENT_ prefixed variables.

ACCOUNTING_AGENT_RUNTIME__ENVIRONMENT=development
ACCOUNTING_AGENT_RUNTIME__DEBUG=false
ACCOUNTING_AGENT_RUNTIME__SERVICE_NAME=accounting-ai-agent
ACCOUNTING_AGENT_RUNTIME__TIMEZONE_NAME=Africa/Lagos
ACCOUNTING_AGENT_RUNTIME__API_BASE_PATH=/api

ACCOUNTING_AGENT_LOGGING__LEVEL=INFO
ACCOUNTING_AGENT_LOGGING__FORMAT=json
ACCOUNTING_AGENT_LOGGING__INCLUDE_STACK_INFO=false

ACCOUNTING_AGENT_API__HOST=127.0.0.1
ACCOUNTING_AGENT_API__PORT=8000
ACCOUNTING_AGENT_API__RELOAD=false
ACCOUNTING_AGENT_API__REQUEST_TIMEOUT_SECONDS=30

ACCOUNTING_AGENT_WORKER__CONCURRENCY=2
ACCOUNTING_AGENT_WORKER__PREFETCH_MULTIPLIER=1
ACCOUNTING_AGENT_WORKER__MAX_TASKS_PER_CHILD=100

ACCOUNTING_AGENT_DATABASE__HOST=127.0.0.1
ACCOUNTING_AGENT_DATABASE__PORT=5432
ACCOUNTING_AGENT_DATABASE__NAME=accounting_agent
ACCOUNTING_AGENT_DATABASE__USER=accounting_agent
ACCOUNTING_AGENT_DATABASE__PASSWORD=accounting_agent
ACCOUNTING_AGENT_DATABASE__SCHEMA_NAME=public
ACCOUNTING_AGENT_DATABASE__ECHO_SQL=false

ACCOUNTING_AGENT_REDIS__BROKER_URL=redis://127.0.0.1:6379/0
ACCOUNTING_AGENT_REDIS__RESULT_BACKEND_URL=redis://127.0.0.1:6379/1
ACCOUNTING_AGENT_REDIS__CACHE_URL=redis://127.0.0.1:6379/2

ACCOUNTING_AGENT_STORAGE__ENDPOINT=127.0.0.1:9000
ACCOUNTING_AGENT_STORAGE__ACCESS_KEY=minioadmin
ACCOUNTING_AGENT_STORAGE__SECRET_KEY=minioadmin
ACCOUNTING_AGENT_STORAGE__SECURE=false
ACCOUNTING_AGENT_STORAGE__REGION=us-east-1
ACCOUNTING_AGENT_STORAGE__DOCUMENT_BUCKET=close-run-documents
ACCOUNTING_AGENT_STORAGE__ARTIFACT_BUCKET=close-run-artifacts
ACCOUNTING_AGENT_STORAGE__DERIVATIVE_BUCKET=close-run-derivatives

ACCOUNTING_AGENT_MODEL_GATEWAY__PROVIDER=openrouter
ACCOUNTING_AGENT_MODEL_GATEWAY__BASE_URL=https://openrouter.ai/api/v1
ACCOUNTING_AGENT_MODEL_GATEWAY__API_KEY=
ACCOUNTING_AGENT_MODEL_GATEWAY__DEFAULT_MODEL=openai/gpt-4.1-mini
ACCOUNTING_AGENT_MODEL_GATEWAY__TIMEOUT_SECONDS=60

ACCOUNTING_AGENT_QUICKBOOKS__CLIENT_ID=
ACCOUNTING_AGENT_QUICKBOOKS__CLIENT_SECRET=
ACCOUNTING_AGENT_QUICKBOOKS__REDIRECT_URI=http://127.0.0.1:8000/api/integrations/quickbooks/callback
ACCOUNTING_AGENT_QUICKBOOKS__SANDBOX_COMPANY_ID=
ACCOUNTING_AGENT_QUICKBOOKS__USE_SANDBOX=true

ACCOUNTING_AGENT_OBSERVABILITY__ENABLED=true
ACCOUNTING_AGENT_OBSERVABILITY__SERVICE_NAMESPACE=accounting-agent
ACCOUNTING_AGENT_OBSERVABILITY__OTLP_ENDPOINT=http://127.0.0.1:4317
ACCOUNTING_AGENT_OBSERVABILITY__SAMPLE_RATIO=1.0

ACCOUNTING_AGENT_SECURITY__SESSION_SECRET=change-me-before-demo-auth
ACCOUNTING_AGENT_SECURITY__TOKEN_SIGNING_SECRET=change-me-before-cli-auth
