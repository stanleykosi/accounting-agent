{
  "name": "@accounting-ai-agent/desktop-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js desktop UI for the Accounting AI Agent local demo, packaged later as a Tauri sidecar.",
  "scripts": {
    "build": "next build",
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "lint": "pnpm exec eslint . --max-warnings 0",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "typecheck": "pnpm exec tsc --project tsconfig.json --pretty false --noEmit"
  },
  "dependencies": {
    "@accounting-ai-agent/ts-sdk": "workspace:*",
    "@accounting-ai-agent/ui": "workspace:*",
    "next": "16.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  }
}
