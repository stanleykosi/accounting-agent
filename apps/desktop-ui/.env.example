# Purpose: Document the canonical environment variables for the Next.js desktop UI.
# Scope: Server-side frontend runtime configuration for auth proxying, middleware session checks,
# and protected-route handling.
# Dependencies: apps/desktop-ui/src/lib/auth/session.ts and apps/desktop-ui/src/middleware.ts.

# Canonical FastAPI base URL used by the desktop UI's same-origin auth proxy and middleware.
ACCOUNTING_AGENT_API_URL=http://127.0.0.1:8000/api

# Must stay aligned with the backend `security_session_cookie_name` setting.
ACCOUNTING_AGENT_SESSION_COOKIE_NAME=accounting_agent_session
